# Database
POSTGRES_PASSWORD=secret

# Paheko (identity provider)
PAHEKO_URL=https://paheko.mamerknights.lu
PAHEKO_API_USER=api
PAHEKO_API_PASS=xxxxx
# Map Paheko category IDs to app roles: categoryId:ROLE,...
PAHEKO_ROLE_MAP=1:PLAYER,2:COACH,3:COMITE

# Auth
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-generate-64-random-chars

# Web Push (VAPID keys)
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:noreply@mamerknights.lu

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@mamerknights.lu
SMTP_PASS=xxxxx

# App
APP_URL=https://app.mamerknights.lu
OTP_EXPIRY_MINUTES=10
SESSION_DAYS=30
